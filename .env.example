# ─── Core Auth ────────────────────────────────────────────────────────────────
# Strong random string used to sign JWT session cookies. Change before launch.
JWT_SECRET="replace-me-with-a-long-random-string"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in Supabase dashboard → Project Settings → API
# Without these the app runs entirely on in-memory demo data (resets on restart).
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Payments (PayMongo) ──────────────────────────────────────────────────────
# https://dashboard.paymongo.com → Developers → API Keys
# Required for GCash and Maya checkout. Without it, payment routes are skipped.
PAYMONGO_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY="pk_live_..."

# ─── SMS (Semaphore) ──────────────────────────────────────────────────────────
# https://semaphore.co → Account → API Key
# Required for OTP login via SMS. Without it, OTP codes are logged to console only.
SEMAPHORE_API_KEY="your-semaphore-api-key"
SEMAPHORE_SENDER_NAME="KASARISARI"

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate once with: npx web-push generate-vapid-keys
# Public key is exposed to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@ka-sari-sari.com"
