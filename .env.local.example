# Ka Sari-Sari — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (Database, Auth, Realtime) ──────────────────────────────────────
# Create project at: https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here
OTP_SECRET=your-otp-secret-here

# ─── PayMongo (GCash, Maya, QRPh, cards, banks) ───────────────────────────────
# Dashboard: https://dashboard.paymongo.com/developers
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Semaphore (PH SMS — Globe + Smart) ──────────────────────────────────────
# Sign up at: https://semaphore.co
SEMAPHORE_API_KEY=your-semaphore-api-key

# ─── Web Push (VAPID — PWA push notifications) ────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BF...your-public-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BF...your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# ─── Anthropic (AI order assistant + demand forecasting) ──────────────────────
# Console: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Maps (driver tracking, routing) ───────────────────────────────────
# Console: https://console.cloud.google.com → Maps JavaScript API
GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ─── Vercel Blob (product images, POD photos) ─────────────────────────────────
# Added automatically when you run: vercel link && vercel storage create blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── App Config ────────────────────────────────────────────────────────────────
# UUID of the Metro Manila hub warehouse from 002_seed_users.sql
DEFAULT_WAREHOUSE_ID=11111111-1111-1111-1111-111111111111
